        "aws/suspension.ts",
        "azure/index.ts",
        "azure/oceanNp.ts",
        "azure/oceanNpVirtualNodeGroup.ts",
        "config/index.ts",
        "config/vars.ts",
        "credentialsAzure.ts",
        "credentialsGcp.ts",
        "dataIntegration.ts",
        "ecs/index.ts",
        "ecs/ocean.ts",
        "ecs/oceanLaunchSpec.ts",
        "elastigroupAzureV3.ts",
        "gcp/elastigroup.ts",
        "gcp/index.ts",
        "gke/elastigroup.ts",
        "gke/index.ts",
